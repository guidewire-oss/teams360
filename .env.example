# =============================================================================
# Team360 Environment Variables
# Copy this file to .env and update with your values
# =============================================================================

# Database connection (REQUIRED)
# Format: postgres://[user]:[password]@[host]:[port]/[database]?sslmode=[mode]
# SSL modes: disable (dev only), require, verify-ca, verify-full (recommended)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/teams360?sslmode=disable

# API Configuration
API_PORT=8080
GIN_MODE=release  # Options: debug, release

# Frontend Configuration
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8080

# Email — AWS SES (preferred, leave blank to fall back to SMTP or disable)
AWS_SES_REGION=
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_ACCESS_KEY=
SES_FROM_ADDRESS=noreply@teams360.example.com

# Email — SMTP (fallback if SES is not configured, leave blank to disable)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@teams360.example.com

# Docker Image Version (for docker-compose)
VERSION=latest
